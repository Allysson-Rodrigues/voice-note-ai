# Azure Speech-to-Text
AZURE_SPEECH_KEY="YOUR_AZURE_SPEECH_KEY"
AZURE_SPEECH_REGION="brazilsouth"
AZURE_SPEECH_LANGUAGE="pt-BR"

# App
VOICE_HOTKEY="CommandOrControl+Super"
VOICE_HOTKEY_FALLBACK="CommandOrControl+Super+Space"
VOICE_HOLD_TO_TALK=1
# Optional: comma-separated hints for better recognition of names/slang/English words
# VOICE_PHRASES="hey,workspace,checkup,Slack,Notepad"
VOICE_HUD=1
# VOICE_HUD_DEBUG=1
# Optional explicit keycodes (Windows/libuiohook): Ctrl(L)=29, Ctrl(R)=3613, Meta(L)=3675, Meta(R)=3676
# VOICE_HOLD_KEYCODES="29,3675"
# Optional tone profile: formal | casual | very-casual
# VOICE_TONE="casual"
VOICE_AUTO_PASTE=1
# Optional hard session timeout (seconds, clamp 30-600)
# VOICE_MAX_SESSION_SECONDS=90
